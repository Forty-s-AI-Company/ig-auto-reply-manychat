DATABASE_URL="postgresql://postgres.project-ref:url-encoded-password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres:url-encoded-password@db.project-ref.supabase.co:5432/postgres?sslmode=require"
DB_PW="<supabase-database-password>"
AUTH_SECRET="<generate-32-plus-character-secret>"
APP_DOMAIN="ig-reply.carry-digital-nomad.in.net"
APP_URL="https://ig-reply.carry-digital-nomad.in.net"

# Google Sign-In. Redirect URI:
# https://your-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="<set-a-strong-admin-password>"
ADMIN_NAME="Admin"

DEMO_LINK="https://example.com/demo-download"

# Optional. Empty means AI FAQ falls back to deterministic local retrieval.
# Use AI_PROVIDER="codex_cli" on a local machine that has Codex CLI installed and logged in.
AI_PROVIDER=""
CODEX_CLI_COMMAND="codex"
CODEX_CLI_TIMEOUT_MS="45000"
OPENAI_API_KEY=""
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
AI_DEFAULT_PROVIDER=
AI_DEFAULT_MODEL=

# Telegram Bot API. Leave empty until you create a bot with BotFather.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""

# Email SMTP channel. EMAIL_SMTP_SECURE=true usually means port 465; false usually means 587.
EMAIL_SMTP_HOST=""
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_SECURE="false"
EMAIL_SMTP_USER=""
EMAIL_SMTP_PASSWORD=""
EMAIL_FROM=""
EMAIL_FROM_NAME="InboxPilot"
EMAIL_DEFAULT_SUBJECT="InboxPilot message"

# Optional. Protects /api/webhooks/mock when used outside the logged-in admin UI.
MOCK_WEBHOOK_SECRET=""

# Optional. Protects /api/automation-webhooks/[key].
# Send x-inboxpilot-signature as sha256=<hex hmac of the raw request body>.
AUTOMATION_WEBHOOK_SECRET=""

# Official Meta / WhatsApp API scaffold only. The app will not fake success.
META_VERIFY_TOKEN=""
META_GRAPH_API_VERSION="v25.0"
META_APP_ID=""
META_APP_SECRET=""
META_FACEBOOK_REDIRECT_URI="https://ig-reply.carry-digital-nomad.in.net/api/meta/oauth/callback"
META_INSTAGRAM_REDIRECT_URI="https://inboxpilot.carry-digital-nomad.in.net/api/instagram/oauth/callback"
META_USER_ACCESS_TOKEN=""
META_USER_ACCESS_TOKEN_EXPIRES_AT=""
META_PAGE_ID=""
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=""
META_TOKEN_RENEWAL_WINDOW_DAYS="14"
META_PAGE_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

