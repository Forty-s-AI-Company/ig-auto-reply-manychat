# Supabase
# Prisma uses DATABASE_URL. For Supabase, set DATABASE_URL to the Supabase Postgres pooler URL.
# Example shape only:
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
TEST_DATABASE_URL="postgresql://postgres.project-ref:url-encoded-password@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
TEST_DIRECT_URL="postgresql://postgres:url-encoded-password@db.project-ref.supabase.co:5432/postgres?sslmode=require"
